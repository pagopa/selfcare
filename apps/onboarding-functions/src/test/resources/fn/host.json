{
  "version": "2.0",
  "functionTimeout": "00:10:00",
  "logging": {
    "logLevel": {
      "default": "Information",
      "Worker": "Information",
      "Host.Startup": "Information",
      "Host.Function.Console": "Information",
      "Microsoft.Azure.WebJobs.Script.Grpc": "Information",
      "DurableTask.AzureStorage": "Warning",
      "DurableTask.Core": "Warning"
    }
  },
  "extensions": {
    "durableTask": {
      "hubName": "JavaTestHub",
      "maxConcurrentActivityFunctions": 10
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 4.8.1)"
  }
}
